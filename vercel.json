{
  "redirects": [
    {
      "source": "/en/:path*",
      "destination": "/:path*?lang=en",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/admin/:path*",
      "destination": "/admin/index.html"
    },
    {
      "source": "/((?!admin|assets|images|vite.svg).*)",
      "destination": "/index.html"
    }
  ]
}
